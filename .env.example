# ZeroTier Moon — DS918+ Configuration
# Copy this file to .env and fill in your values before running install.sh

# ─── ZeroTier ──────────────────────────────────────────────────────────────────
# Your ZeroTier network ID (from my.zerotier.com)
ZT_NETWORK_ID=

# Optional: public IP or DDNS hostname for the moon's stable endpoint
# Leave blank if this NAS has no public IP
ZT_PUBLIC_ENDPOINT=

# ─── LAN 1 (eth0) ──────────────────────────────────────────────────────────────
LAN1_SUBNET=192.168.1.0/24
LAN1_GATEWAY=192.168.1.1
LAN1_CONTAINER_IP=192.168.1.253    # static IP to assign to the container on LAN 1

# ─── LAN 2 (eth1) ──────────────────────────────────────────────────────────────
LAN2_SUBNET=172.16.0.0/24
LAN2_GATEWAY=172.16.0.1
LAN2_CONTAINER_IP=172.16.0.253     # static IP to assign to the container on LAN 2

# ─── Storage ───────────────────────────────────────────────────────────────────
DATA_DIR=/volume1/docker/zerotier

# ─── Container ─────────────────────────────────────────────────────────────────
CONTAINER_NAME=zerotier-moon
IMAGE_NAME=zerotier-moon
